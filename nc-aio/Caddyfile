{
    layer4 {
        127.0.0.1:3478 {
            route {
                proxy {
                    upstream nextcloud-aio-talk:3478
                }
            }
        }
        127.0.0.1:3479 {
            route {
                proxy {
                    upstream nextcloud-aio-talk:3479
                }
            }
        }
    }
}

# Serve upstream service over HTTPS
https://{$CDY_DOMAIN} {
    reverse_proxy nextcloud-aio-apache:11000 nextcloud-aio-domaincheck:11000 {
	lb_policy first
	lb_try_duration 5s
	fail_duration 30s
	# tell the upstream that the original connection was HTTPS
        header_up x-forwarded-proto "https"
        header_up host {host}
    }
}

# Redirect all HTTP requests to HTTPS
http://{$CDY_DOMAIN} {
    redir https://{$CDY_DOMAIN}{uri} permanent
}
